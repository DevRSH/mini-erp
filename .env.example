# ═══════════════════════════════════════════
# Mini ERP — Variables de Entorno
# Copia este archivo como .env y ajusta los valores
# ═══════════════════════════════════════════

# Autenticación
APP_PIN=1234
SECRET_KEY=cambiar-esta-clave-por-una-segura
SESSION_HOURS=24

# Cookies
COOKIE_SECURE=false
COOKIE_HTTPONLY=true
COOKIE_SAMESITE=lax

# Backup
BACKUP_KEY=mi-clave-de-backup

# Base de datos
DB_PATH=data/erp.db

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# JWT
JWT_ALGORITHM=HS256
